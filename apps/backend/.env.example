# Server binds on PORT; clients talk via Caddy hostname (no :port in URLs).
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
BETTER_AUTH_SECRET=replace-with-a-secret-at-least-32-characters-long

# On-VPS via Caddy + /etc/hosts (see deploy/Caddyfile):
BETTER_AUTH_URL=http://api.anthiel.local
# Comma-separated — include every dashboard origin that talks to the API
CORS_ORIGIN=http://localhost:3001,http://dashboard.anthiel.local

# Production behind Cloudflare: add public HTTPS hostnames too, e.g.
# BETTER_AUTH_URL=https://api.yourdomain.com
# CORS_ORIGIN=http://localhost:3001,http://dashboard.anthiel.local,https://dashboard.yourdomain.com
# (browser auth cookies must match the origin users open)

PORT=3002
